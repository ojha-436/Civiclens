rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Quiz scores — authenticated users can create only, with strict schema validation.
    // No reads, updates, or deletes permitted from client.
    match /quiz_scores/{scoreId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['uid', 'score', 'tier', 'timestamp'])
        && request.resource.data.keys().size() == 4
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 7
        && request.resource.data.tier is string
        && request.resource.data.tier in ['Civic Expert', 'Informed Voter', 'Keep learning']
        && request.resource.data.timestamp is timestamp;

      allow read, update, delete: if false;
    }

    // Default: deny all access to any other collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
